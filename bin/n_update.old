#!/bin/bash   
#
#	nucore update script v1.0
#	Copyright 2010 Big Guys Pinball LLC.
#	author: Chuck Hess
#	updated: 10.15.2010
#

command=$1
usbdir=$2

echo 'Nucore USB update running'
echo '-----------------------------------------'

if [ $command = 'copyfiles' ]
	then
		echo 'Copying files from USB'
		
		files=$(ls $usbdir/*.mp3 2> /dev/null | wc -l)
		if [ "$files" != "0" ]
			then 
				echo 'mp3s found'
				cp $usbdir/*.mp3 ../music
			else
				echo 'no mp3s found'
		fi

		if [ -d "$usbdir/update" ]
			then
				echo 'update directory found'
				cp -r -f $usbdir/update/* ../update/
			else
				echo 'no update found'	
		fi		

		if [ -f "$usbdir/nucore" ]
			then
				echo 'nucore update found'
				cp $usbdir/nucore ../download
			else
				echo 'no nucore update found'	
		fi
	
		if [ -f "$usbdir/run" ]
			then
				echo 'nucore launcher update found'
				cp $usbdir/run ../download
			else
				echo 'no nucore launcher update found'
		fi

		if [ -f "$usbdir/n_update" ]
			then
				echo 'nucore update script found'
				cp $usbdir/n_update ../download
			else
				echo 'no nucore update script found'
		fi

		if [ -f "$usbdir/leds.cfg" ]
			then
				echo 'LED config file found'
				cp -f $usbdir/leds.cfg ../config
			else
				echo 'no LED config file found'
		fi
		
		if [ -f "$usbdir/servers.txt" ]
			then
				echo 'servers.txt file found'
				cp -f $usbdir/servers.txt ../config
			else
				echo 'no servers.txt file found'
		fi

		if [ -f "$usbdir/nts" ]
			then
				echo 'nts file found'
				cp -f $usbdir/nts ../bin
			else
				echo 'no nts file found'
		fi

		if [ -f "$usbdir/load_screen.bmp" ]
			then
				echo 'load screen file found'
				cp -f $usbdir/load_screen.bmp ../resources/load/swe1/swe1_load_screen_s0.bmp
				cp -f $usbdir/load_screen.bmp ../resources/load/rfm/rfm_load_screen_s0.bmp
			else
				echo 'no load screen file found'
		fi

		echo'copying log files to usb'
		cp -r ../logs $usbdir
		
		sync
		
	else if [ $command = 'updatebin' ]
		
		then
			echo 'Checking for file updates'
			
			if [ -f "../download/nucore" ]
				then
					echo 'upgrading nucore'
					cp ../download/nucore ./
			fi
		
			if [ -f "../download/n_update" ]
				then
					echo 'upgrading nucore usb update'
					cp ../download/n_update ./ 
			fi
			
			files=$(ls ../download/* 2> /dev/null | wc -l)
			if [ "$files" != "0" ]
				then
					rm ../download/*
			fi
	fi
fi

echo '-----------------------------------------'
echo 'Done'
echo ''

