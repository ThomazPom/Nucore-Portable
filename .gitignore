# Editor backups
*~
*.swp
*.swo
.#*
\#*\#

# Build artefacts (sigio_fix.so is shipped pre-built but rebuildable)
# Keep the .so committed so people without a 32-bit toolchain still get
# a working bundle on first clone; uncomment if you want it untracked.
#bin/sigio_fix.so

# Runtime savedata produced by the emulator. The shipped roms/savedata
# directory itself is intentionally tracked (it holds the per-cabinet
# .nvram / .flash / .ems / .see snapshots), but ignore the OS junk that
# accumulates inside it.
.DS_Store
Thumbs.db

# Community / post-Williams update bundles (Jim Askey @ mypinballs.com).
# nucore-portable runs them fine but does not redistribute them — see
# the "Community updates (mypinballs.com)" section in README.md.
# Files are dropped flat into update/swe1_14/ or update/rfm_15/, so we
# guard against committing them by their version-stamped filenames.
update/*/pin2000_50069_0210_*
update/*/pin2000_50070_0250_*
update/*/pin2000_50070_0260_*
